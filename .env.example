# ============================================================
# AI Value Investor — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git
# ============================================================

# ── LLM API Keys ─────────────────────────────────────────
# Primary: OpenAI (required for report writing, Buffett/Graham Agents)
OPENAI_API_KEY=your-openai-api-key-here

# Secondary: Anthropic Claude (fallback)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Low-cost: DeepSeek (news sentiment, document extraction)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── Data Sources ─────────────────────────────────────────
# FMP API for HK/US deep financial data ($15/month Starter plan)
# Get from: https://financialmodelingprep.com/
FMP_API_KEY=your-fmp-api-key-here

# ── Telegram Notification ────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → get BOT_TOKEN
# 2. Send any message to your bot
# 3. Visit https://api.telegram.org/bot{TOKEN}/getUpdates → get chat.id
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# ── Email Notification (legacy Brevo, optional) ──────────
# Brevo SMTP requires verified domain — not recommended for personal use
BREVO_API_KEY=
EMAIL_RECIPIENT=
EMAIL_SENDER_NAME=AI Value Investor
EMAIL_SENDER_EMAIL=

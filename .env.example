# ============================================================
# AI Value Investor — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git
# ============================================================

# ── LLM API Keys ─────────────────────────────────────────
# Primary: OpenAI (required for report writing, Buffett/Graham Agents)
OPENAI_API_KEY=your-openai-api-key-here

# Secondary: Anthropic Claude (fallback)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Low-cost: DeepSeek (news sentiment, document extraction)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── Data Sources ─────────────────────────────────────────
# FMP API for HK/US deep financial data ($15/month Starter plan)
# Get from: https://financialmodelingprep.com/
FMP_API_KEY=your-fmp-api-key-here

# ── QVeris API Keys (for A-share financial data fallback) ──
# You can provide multiple keys separated by commas. The system will
# automatically rotate to the next key if one runs out of credits (HTTP 402).
QVERIS_API_KEYS=key1,key2,key3

# ── Telegram Notification ────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → get BOT_TOKEN
# 2. Send any message to your bot
# 3. Visit https://api.telegram.org/bot{TOKEN}/getUpdates → get chat.id
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# ── Email Notification (legacy Brevo, optional) ──────────
# Brevo SMTP requires verified domain — not recommended for personal use
BREVO_API_KEY=
EMAIL_RECIPIENT=
EMAIL_SENDER_NAME=AI Value Investor
EMAIL_SENDER_EMAIL=

# ── Network / Proxy Configuration ─────────────────────────
# Set these if you're behind a corporate proxy or VPN
# LLM API domains (openai, anthropic, deepseek) BYPASS proxy by default
# as they usually work better with direct connections
#
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
#
# Domains to bypass proxy (comma-separated, supports wildcards)
# Default bypassed: api.openai.com, api.anthropic.com, api.deepseek.com, api.tavily.com
# NO_PROXY=localhost,127.0.0.1,*.local
#
# ── Proxy Bypass Control ──
# PROXY_BYPASS_LLM=true     # Set to "false" to use proxy for LLM APIs
# PROXY_BYPASS_CHINA=false  # Set to "true" if in China (bypass proxy for Sina, etc.)
#
# Example: If you're in China with VPN running but want domestic sites direct:
#   PROXY_BYPASS_CHINA=true

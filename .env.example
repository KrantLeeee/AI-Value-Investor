# ============================================================
# AI Value Investor — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git
# ============================================================

# ── LLM API Keys ─────────────────────────────────────────
# Primary: OpenAI (required for report writing, Buffett/Graham Agents)
OPENAI_API_KEY=your-openai-api-key-here

# Secondary: Anthropic Claude (fallback)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Low-cost: DeepSeek (news sentiment, document extraction)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── Data Sources ─────────────────────────────────────────
# FMP API for HK/US deep financial data ($15/month Starter plan)
# Get from: https://financialmodelingprep.com/
FMP_API_KEY=your-fmp-api-key-here

# ── Email Notification ───────────────────────────────────
# Brevo (formerly Sendinblue) — free 300 emails/day
# Get from: https://www.brevo.com/
BREVO_API_KEY=your-brevo-api-key-here
EMAIL_RECIPIENT=your-email@example.com
EMAIL_SENDER_NAME=AI Value Investor
EMAIL_SENDER_EMAIL=noreply@yourapp.com

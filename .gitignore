# ============================================================
# AI Value Investor — .gitignore
# ============================================================

# References folder (docs, source references — not tracked)
References/

# Environment & secrets
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Poetry
poetry.lock

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Database (local data — not tracked in git)
data/db/
data/cache/
data/manual/

# Output files (generated — not tracked)
output/

# Logs
*.log
logs/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# pytest
.pytest_cache/
.coverage
htmlcov/

# mypy / ruff
.mypy_cache/
.ruff_cache/
